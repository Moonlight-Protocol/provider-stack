# provider-stack — self-host environment.
#
#   cp .env.example .env   then fill the values below and run:  docker compose up --build
#
# Vars are read by crates/core/src/config.rs (Config::from_env). Everything not
# marked "optional" is REQUIRED — the app refuses to boot without it. Lines
# marked SECRET must be kept out of version control (.env is gitignored).
#
# NOTE: keep comments on their OWN line. docker compose env_file does NOT strip
# inline `# ...` after a value — it would become part of the value.
#
# Generate the two key secrets with the bundled CLI (no Postgres needed):
#   docker compose run --rm --no-deps app genkey              -> PP_SECRET_KEY + PP_PUBLIC_KEY
#   docker compose run --rm --no-deps app gen-service-secret  -> SERVICE_AUTH_SECRET

# ============================================================================
# Postgres (the `db` compose service) + the app's connection string
# ============================================================================
# The `db` service is created with these. DATABASE_URL is overridden in
# docker-compose.yml to always point at the `db` service using these same
# values, so keep them consistent if you change them.
POSTGRES_USER=provider
# SECRET — change for production.
POSTGRES_PASSWORD=provider
POSTGRES_DB=provider_stack
# REQUIRED. Used when running the binary outside compose; inside compose it is
# overridden to postgres://<user>:<pass>@db:5432/<db>.
DATABASE_URL=postgres://provider:provider@db:5432/provider_stack

# ============================================================================
# Stellar network + RPC  (RPC is EXTERNAL — not a container)
# ============================================================================
# REQUIRED — testnet | mainnet | local
NETWORK=testnet
# REQUIRED — base fee in stroops.
NETWORK_FEE=100
# Point at a real RPC for your network. If unset, the app falls back to a
# per-network default (testnet -> https://soroban-testnet.stellar.org).
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# optional (default 1000)
TRANSACTION_EXPIRATION_OFFSET=1000

# ============================================================================
# Provider identity + service auth
# ============================================================================
# REQUIRED — SEP-10 home domain.
SERVICE_DOMAIN=localhost:3000
# REQUIRED, SECRET — `gen-service-secret`.
SERVICE_AUTH_SECRET=replace-me
# REQUIRED — operator wallet public key (SEP-43 dashboard), G...
OPERATOR_PUBLIC_KEY=G...
# REQUIRED, SECRET — privacy-provider key, `genkey`, S...
PP_SECRET_KEY=S...
# optional (default http://localhost:<PORT>)
PROVIDER_BASE_URL=http://localhost:3000

# ============================================================================
# Sessions / SEP-10 challenge lifetimes (seconds)
# ============================================================================
# REQUIRED
CHALLENGE_TTL=300
# REQUIRED
SESSION_TTL=86400

# ============================================================================
# Mempool / executor / verifier tuning
# ============================================================================
# REQUIRED
MEMPOOL_SLOT_CAPACITY=100
# REQUIRED
MEMPOOL_EXPENSIVE_OP_WEIGHT=10
# REQUIRED
MEMPOOL_CHEAP_OP_WEIGHT=1
# REQUIRED
MEMPOOL_EXECUTOR_INTERVAL_MS=5000
# REQUIRED
MEMPOOL_VERIFIER_INTERVAL_MS=5000
# REQUIRED
MEMPOOL_TTL_CHECK_INTERVAL_MS=10000
# REQUIRED
MEMPOOL_MAX_RETRY_ATTEMPTS=3
# optional (default 0 = no age cap on boot)
MEMPOOL_STARTUP_MAX_BUNDLE_AGE_MS=0
# REQUIRED
BUNDLE_MAX_OPERATIONS=100
# optional (default 30000)
EVENT_WATCHER_INTERVAL_MS=30000

# ============================================================================
# Server
# ============================================================================
# optional (default 3000)
PORT=3000
# optional — development | production
MODE=development
# optional — tracing EnvFilter (e.g. info, debug, provider_stack_api=debug)
LOG_LEVEL=info
# optional — comma-separated CORS origins (e.g. https://console.example.com).
# Each entry must be a full origin (scheme + host[:port]); leave empty for none.
ALLOWED_ORIGINS=

# ============================================================================
# Observability (OPTIONAL — see the commented `jaeger` service in compose)
# ============================================================================
# If unset, traces are dropped silently — observability is not a hard dependency.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# OTEL_SERVICE_NAME=provider-stack
